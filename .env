# Configuración de Tarifas - Electricidad Verde
# Estos valores se pueden modificar sin necesidad de cambiar el código

# === ELECTRICIDAD ===
# Precio de nuestra tarifa de electricidad (€/kWh)
ELECTRICITY_PRICE_KWH=0.11

# Precio por defecto que ve el usuario en el input (€/kWh)
ELECTRICITY_DEFAULT_USER_PRICE=0.16

# Perfiles de consumo eléctrico mensual (kWh)
ELECTRICITY_CONSUMPTION_LOW=150
ELECTRICITY_CONSUMPTION_MEDIUM=300
ELECTRICITY_CONSUMPTION_HIGH=500

# === GAS ===
# Precio de nuestra tarifa de gas (€/kWh)
GAS_PRICE_KWH=0.05

# Precio por defecto que ve el usuario en el input (€/kWh)
GAS_DEFAULT_USER_PRICE=0.10

# Perfiles de consumo de gas mensual (kWh)
GAS_CONSUMPTION_LOW=100
GAS_CONSUMPTION_MEDIUM=200
GAS_CONSUMPTION_HIGH=400

# === CONTACTO ===
# Página del formulario de contacto
FORMULARIO=https://forms.gle/1spNJwHp2mLhzmCd6

# === LEGAL ===
# URL de la política de privacidad (obligatorio para Google Play/App Store)
# Crea una página web con tu política y pon aquí la URL
PRIVACY_POLICY_URL=https://serberar.github.io/privacidad/